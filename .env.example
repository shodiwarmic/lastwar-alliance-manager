# ==========================================
# Last War Alliance Manager - Environment Setup
# ==========================================

# --- Core Security ---
# Must be a 64-character hex string. 
# Generate via: openssl rand -hex 32
SESSION_KEY=your_64_character_hex_string_here

# 32-byte hex-encoded string for AES-GCM encryption of external API credentials.
# Generate one using: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=your_32_byte_hex_string_here

# --- Storage Paths (Docker Defaults) ---
# When running in Docker, these map to the internal container paths.
DATABASE_PATH=/app/data/alliance.db
STORAGE_PATH=/app/uploads

# --- Environment Flags ---
# Set both to 'true' in production to enforce secure, encrypted cookies.
# Set to 'false' for local HTTP testing.
PRODUCTION=true
HTTPS=true

# --- Domains & Routing ---
# The domains where your application and document server live.
# Note: Do not include http:// or https:// here.
APP_DOMAIN=app.example.com
COLLABORA_DOMAIN=collabora.example.com

# --- Security (CSRF) ---
# A comma-separated list of exact domains/IPs allowed to submit forms.
# MUST include the port if accessing via a non-standard port locally.
TRUSTED_ORIGINS=app.example.com, localhost:8080, 127.0.0.1:8080

# --- OCR Request Archival (optional, off by default) ---
# Retains uploaded screenshots + the parsed OCR response for improving OCR /
# diagnosing mistakes. The destination (none/gcp/local/both) and GCS bucket are
# configured in Admin → Security, NOT here. These two vars only set up the
# LOCAL-disk destination's prerequisites.
#
# Host path for local-disk archival. Empty = local archival option disabled.
# DOCKER WARNING: this MUST be inside a mounted volume — the default
# /app/data/ocr-archive lives under the existing ./data mount. A path NOT mounted
# (e.g. /var/log/archives) writes to the container's ephemeral layer and is LOST
# on the next recreate/update. To relocate, bind-mount your disk at the host's
# ./data/ocr-archive instead of changing this path.
OCR_ARCHIVE_DIR=
# Days to retain local archives before the in-app janitor prunes them (default 7;
# local archives live on the host disk). Negative disables in-app pruning (manage
# cleanup yourself — see DEPLOYMENT.md). Ignored when OCR_ARCHIVE_DIR is unset.
OCR_ARCHIVE_RETENTION_DAYS=7