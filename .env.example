# ==========================================
# Last War Alliance Manager - Environment Setup
# ==========================================

# --- Core Security ---
# Must be a 64-character hex string. 
# Generate via: openssl rand -hex 32
SESSION_KEY=your_64_character_hex_string_here

# 32-byte hex-encoded string for AES-GCM encryption of external API credentials.
# Generate one using: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=your_32_byte_hex_string_here

# --- Storage Paths (Docker Defaults) ---
# When running in Docker, these map to the internal container paths.
DATABASE_PATH=/app/data/alliance.db
STORAGE_PATH=/app/uploads

# --- Environment Flags ---
# Set both to 'true' in production to enforce secure, encrypted cookies.
# Set to 'false' for local HTTP testing.
PRODUCTION=true
HTTPS=true

# --- Domains & Routing ---
# The domains where your application and document server live.
# Note: Do not include http:// or https:// here.
APP_DOMAIN=app.example.com
COLLABORA_DOMAIN=collabora.example.com

# --- Security (CSRF) ---
# A comma-separated list of exact domains/IPs allowed to submit forms.
# MUST include the port if accessing via a non-standard port locally.
TRUSTED_ORIGINS=app.example.com, localhost:8080, 127.0.0.1:8080